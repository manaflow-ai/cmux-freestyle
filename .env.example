# Required. Get one from https://dash.freestyle.sh.
FREESTYLE_API_KEY=

# Optional. Pin to a specific manaflow-ai/cmux release tag. Defaults to latest stable.
# CMUX_RELEASE_TAG=v0.9.42

# Optional. Override the snapshot name. Defaults to cmux-freestyle-<timestamp>.
# CMUX_FREESTYLE_SNAPSHOT_NAME=cmux-freestyle-prod

# Optional. Force Freestyle to rebuild instead of reusing its layer cache.
# CMUX_FREESTYLE_SKIP_CACHE=1
